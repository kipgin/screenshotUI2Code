# AI Frontend Designer — Backend Config
# Copy to .env and fill in your values

# ── LLM ──────────────────────────────────────────────────────────────────────
SMALL_MODEL_PROVIDER=openai
SMALL_MODEL_NAME=qwen2.5-coder-ov
SMALL_MODEL_BASE_URL=http://localhost:8000/v1
SMALL_MODEL_API_KEY=local-gpu

# ── Agent ─────────────────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=10
HISTORY_SUMMARIZE_THRESHOLD=6000

# ── Parallelism ────────────────────────────────────────────────────────────────
# Can be overridden per-request via enable_parallel form field
ENABLE_PARALLEL_GENERATION=false

# ── Git ───────────────────────────────────────────────────────────────────────
GIT_AUTO_COMMIT=true
GIT_WORKSPACE_ROOT=./workspaces

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8001
HOST=0.0.0.0
DEBUG=true
