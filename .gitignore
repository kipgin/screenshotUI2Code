# ==========================================
# Root & System Files
# ==========================================
.vscode/
.idea/
*.log
.DS_Store
Thumbs.db

# ==========================================
# Python & Backend (backend/)
# ==========================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Pytest / unit tests cache
.pytest_cache/

# Local Environment Variables (Contains sensitive API keys, secrets)
backend/.env
backend/.env.local
backend/.env.*.local

# Dynamic / Generated directories (Only ignore contents, keep the directory)
backend/uploads/*
!backend/uploads/.gitkeep

backend/workspaces/*
!backend/workspaces/.gitkeep

