# Model Inference (model_inference/)
# ==========================================

model_inference/qwen2.5_coder_3b_openvino_int4/
model_inference/qwen2.5_coder_7b_openvino_int4/
model_inference/testing_infer/gemma-3-4b-it-int4-ov/


model_inference/**/openvino*/
model_inference/**/ov*/
model_inference/**/*.bin
model_inference/**/*.xml
model_inference/**/*.onnx

# Python bytecode inside model_inference
model_inference/__pycache__/

